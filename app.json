{
  "expo": {
    "name": "Deep Strike",
    "slug": "deep-strike",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.deepstrike.app",
      "buildNumber": "1",
      "deploymentTarget": "15.0",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Deep Strike uses speech recognition so you can call out shot coordinates by voice.",
        "NSMicrophoneUsageDescription": "Deep Strike needs microphone access for voice commands.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "Deep Strike uses your advertising ID to show relevant ads. This helps keep the app free to play."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1628"
      },
      "package": "com.deepstrike.app",
      "versionCode": 2,
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2359377961428278~9039839772",
          "iosAppId": "ca-app-pub-2359377961428278~4868660479"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Deep Strike needs microphone access for voice commands."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00E5FF"
        }
      ],
      "@sentry/react-native",
      [
        "expo-iap",
        {}
      ],
      "expo-tracking-transparency"
    ],
    "extra": {
      "eas": {
        "projectId": "a6ee5805-7ef6-4db0-982e-0099da2c289e"
      }
    },
    "owner": "kanupriyam"
  }
}
